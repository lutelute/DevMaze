{
  "name": "devmaze",
  "version": "0.2.0",
  "description": "Git development history visualizer — a maze of your coding journey",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:mcp": "node scripts/build-mcp.cjs",
    "package": "npm run build && npm run build:electron && npm run build:mcp && electron-builder",
    "package:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "d3": "^7.9.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.24.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
